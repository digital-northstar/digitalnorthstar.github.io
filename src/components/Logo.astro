     x="190"
     y="130"
     font-family="Montserrat, system-ui, '-apple-system', BlinkMacSystemFont, 'Segoe UI', sans-serif"
     font-size="28px"
     font-weight="600"
     fill="#0f1c30"
     letter-spacing="3"
     id="text7">NORTHSTAR</text>
