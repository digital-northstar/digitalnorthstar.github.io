       points="100,190 100,100 115,115 "
       fill="url(#faceLight)"
       id="polygon9"
       style="fill:url(#linearGradient22)" />
    <polygon
       points="10,100 85,85 100,100 "
       fill="url(#faceDark)"
       id="polygon10"
       style="fill:url(#linearGradient23)" />
    <polygon
       points="10,100 100,100 85,115 "
       fill="url(#faceLight)"
       id="polygon11"
       style="fill:url(#linearGradient24)" />
  </g>
