       x2="40.824829"
       y2="244.94897"
       gradientTransform="scale(2.4494897,0.40824829)"
       gradientUnits="userSpaceOnUse" />
    <linearGradient
       xlink:href="#faceLight"
       id="linearGradient24"
       x1="4.0824828"
       y1="244.94897"
       x2="40.824829"
       y2="281.69131"
       gradientTransform="scale(2.4494897,0.40824829)"
       gradientUnits="userSpaceOnUse" />
