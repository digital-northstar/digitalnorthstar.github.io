---
interface Props {
  size?: string
  class?: string
  label?: string
}

const {
  size = "h-8 w-8",
  class: extra = "",
  label = "Digital Northstar logo"
} = Astro.props
---

<!--
  Inline SVG logo component
  - size: Tailwind classes (bv. h-6 w-6)
  - class: extra utility classes
  - label: voor screenreaders
-->

<svg
   width="600"
   height="200"
   viewBox="0 0 600 200"
   version="1.1"
   id="svg8"
   xmlns:xlink="http://www.w3.org/1999/xlink"
   xmlns="http://www.w3.org/2000/svg"
   xmlns:svg="http://www.w3.org/2000/svg">
  <!-- Background -->
  <rect
     width="600"
     height="200"
     fill="none"
     id="rect1"
     x="-0.23888743"
     y="-0.95554972" />
  <!-- Emblem circle -->
  <circle
     cx="90"
     cy="100"
     r="55"
     fill="#2f6faf"
     id="circle1"
     style="display:none" />
  <circle
     cx="90"
     cy="100"
     r="55"
     fill="none"
     stroke="#c0c0c0"
     stroke-width="3"
     id="circle2" />
  <!-- North Star with subtle relief (simple gradient) -->
  <defs
     id="defs4">
    <!-- Subtiele reliefgradient in het midden -->
    <linearGradient
       id="faceLight"
       x1="0"
       y1="0"
       x2="1"
       y2="1">
      <stop
         offset="0%"
         stop-color="#f8fbff"
         id="stop1" />
      <stop
         offset="100%"
         stop-color="#bfc7d1"
         id="stop2-0" />
    </linearGradient>
    <linearGradient
       id="faceDark"
       x1="0"
       y1="0"
       x2="1"
       y2="1">
      <stop
         offset="0%"
         stop-color="#9aa5b1"
         id="stop3-9" />
      <stop
         offset="100%"
         stop-color="#5a6572"
         id="stop4-4" />
    </linearGradient>
    <linearGradient
       xlink:href="#faceLight"
       id="linearGradient17"
       x1="244.94897"
       y1="4.0824828"
       x2="281.69131"
       y2="40.824829"
       gradientTransform="scale(0.40824829,2.4494897)"
       gradientUnits="userSpaceOnUse" />
    <linearGradient
       xlink:href="#faceDark"
       id="linearGradient18"
       x1="208.20663"
       y1="4.0824828"
       x2="244.94897"
       y2="40.824829"
       gradientTransform="scale(0.40824829,2.4494897)"
       gradientUnits="userSpaceOnUse" />
