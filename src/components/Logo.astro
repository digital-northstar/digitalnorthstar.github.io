       points="190,100 115,115 100,100 "
       fill="url(#faceLight)"
       id="polygon6-2"
       style="fill:url(#linearGradient19)" />
    <polygon
       points="190,100 100,100 115,85 "
       fill="url(#faceDark)"
       id="polygon7"
       style="fill:url(#linearGradient20)" />
    <polygon
       points="100,190 85,115 100,100 "
       fill="url(#faceDark)"
       id="polygon8"
       style="fill:url(#linearGradient21)" />
