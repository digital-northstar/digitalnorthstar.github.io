       xlink:href="#faceLight"
       id="linearGradient19"
       x1="40.824829"
       y1="244.94897"
       x2="77.567177"
       y2="281.69131"
       gradientTransform="scale(2.4494897,0.40824829)"
       gradientUnits="userSpaceOnUse" />
    <linearGradient
       xlink:href="#faceDark"
       id="linearGradient20"
       x1="40.824829"
       y1="208.20663"
       x2="77.567177"
       y2="244.94897"
       gradientTransform="scale(2.4494897,0.40824829)"
       gradientUnits="userSpaceOnUse" />
    <linearGradient
       xlink:href="#faceDark"
       id="linearGradient21"
       x1="208.20663"
       y1="40.824829"
